---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import PostMeta from "../components/PostMeta.astro";

const entries = (await getCollection("explainers", ({ data }) => import.meta.env.DEV || !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const minutesFor = (body: string | undefined) =>
  Math.max(
    1,
    Math.round(
      (body ?? "")
        .replace(/^import\s.+$|<[^>]+>/gm, " ")
        .split(/\s+/)
        .filter(Boolean).length / 200,
    ),
  );
---

<Layout title="Cutaway" description="Interactive explainers of backend and systems internals — the casing removed.">
  <h1 class="sr-only">Cutaway — interactive explainers of systems internals</h1>
  <p class="prose text-muted mb-12">
    Interactive explainers of backend and systems internals — WALs, Raft, connection pooling, workflow engines — with
    the casing removed. Built for engineers who have been paged at 3 AM.
  </p>
  <ul class="flex flex-col gap-10">
    {
      entries.map((entry) => (
        <li>
          <PostMeta number={entry.data.number} pubDate={entry.data.pubDate} minutes={minutesFor(entry.body)} />
          <h2 class="mt-1 text-lg font-semibold">
            <a href={`/${entry.id}/`} class="hover:underline">
              {entry.data.title}
            </a>
          </h2>
          <p class="text-muted mt-1 max-w-prose">{entry.data.description}</p>
        </li>
      ))
    }
    {entries.length === 0 && <li class="text-muted font-mono text-sm">No explainers published yet. Soon.</li>}
  </ul>
</Layout>
