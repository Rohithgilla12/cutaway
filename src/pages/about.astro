import Layout from "../components/Layout.astro";
---

<Layout title="About — Cutaway" description="What Cutaway is and who writes it.">
  <div class="prose">
    <h1>about</h1>
    <p>
      Cutaway publishes interactive explainers of backend and systems internals: write-ahead logs, Raft, connection
      pooling, durable workflow engines. Each piece is built around one interactive system you can break — kill the
      process mid-write, partition the leader — and watch what happens.
    </p>
    <p>
      The name comes from cutaway diagrams: the machine drawn with its casing removed. Every technical claim is verified
      against primary sources before publishing, and each explainer cites them.
    </p>
    <p>
      Written by <a href="https://github.com/Rohithgilla12">Rohith Gilla</a>.
    </p>
  </div>
</Layout>
