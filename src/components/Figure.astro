---
interface Props {
  number: number;
  label: string;
  caption?: string;
}

const { number, label, caption } = Astro.props;
const annotation = `FIG. ${String(number).padStart(2, "0")} — ${label.toUpperCase()}`;
---

<figure class="my-10 border border-ink bg-raised">
  <figcaption class="flex items-baseline justify-between border-b border-ink px-3 py-1.5 font-mono text-[11px] tracking-wider">
    <span>{annotation}</span>
    <span class="text-muted">INTERACTIVE</span>
  </figcaption>
  <div class="p-4">
    <slot />
  </div>
  {caption && <p class="border-t border-rule px-3 py-2 font-mono text-xs text-muted">{caption}</p>}
</figure>
